DATABASE_URL=sqlite:///./yakgandongui.db
GEMINI_API_KEY=
LAW_API_KEY=

# OCR
# Windows default path after installing Tesseract OCR.
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
TESSDATA_DIR=ocr/tessdata
OCR_LANGUAGE=kor+eng
OCR_PSM=6
OCR_MIN_TEXT_LENGTH=20

# RAG
USE_SEMANTIC_RAG=false
ALLOW_MODEL_DOWNLOAD=false

# KoELECTRA risk classifier
# Base model selected for this project: snunlp/KR-ELECTRA-discriminator.
# It must be fine-tuned as a sequence-classification model before enabling
# runtime risk prediction. Keep USE_KOELECTRA_CLASSIFIER=false until then.
USE_KOELECTRA_CLASSIFIER=false
KOELECTRA_MODEL_NAME_OR_PATH=snunlp/KR-ELECTRA-discriminator
KOELECTRA_DEVICE=-1
KOELECTRA_MAX_LENGTH=256
KOELECTRA_MIN_CONFIDENCE=0.5
KOELECTRA_LABEL_MAP=LABEL_0:LOW,LABEL_1:MEDIUM,LABEL_2:HIGH
